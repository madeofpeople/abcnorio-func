{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "abcnorio/content-listing",
  "title": "Content Listing Block",
  "category": "widgets",
  "icon": "list-view",
  "description": "Lists N events and articles matching configured criteria.",
  "keywords": ["content", "listing", "abcnorio"],
  "attributes": {
    "listingPostTypes": {
      "type": "array",
      "default": ["event", "article"],
      "items": {
        "type": "string"
      }
    },
    "listingTagFilter": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "listingCount": {
      "type": "number",
      "default": 6
    },
    "order": {
      "type": "string",
      "default": "desc"
    },
    "showCount": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "align": false,
    "html": false
  }
}
